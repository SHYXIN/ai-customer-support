# LLM 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.longcat.chat/openai
OPENAI_MODEL=LongCat-2.0-Preview

# BGE 嵌入模型路径（相对 backend/ 目录）
BGE_MODEL_PATH=../bge-small-zh-v1.5/fast-bge-small-zh-v1.5

# Bitext 数据路径（相对 backend/ 目录）
BITEXT_DATA_DIR=../bitext_cn

# Chroma 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma
